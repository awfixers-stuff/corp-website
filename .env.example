DATABASE_URI=mongodb://localhost:27017/payload-website
PAYLOAD_SECRET=YOUR_PAYLOAD_SECRET

NEXT_PUBLIC_SITE_URL=http://local.corp.awfixer.me:3000

# Used to preview draft pages and revalidate them
NEXT_PRIVATE_DRAFT_SECRET=demo_draft_secret
NEXT_PRIVATE_REVALIDATION_KEY=demo_revalidation_key

# The GitHub Access Token is used to dynamically fetch docs from GitHub and write them to a JSON file within this repo
GITHUB_ACCESS_TOKEN=

# This is used to generate the sitemap, i.e. https://corp.awfixer.me
SITEMAP_URL=

# Vercel Cron Job
NEXT_PRIVATE_CRON_KEY=a-bunch-of-random-text-and-numbers

NEXT_PUBLIC_NEWSLETTER_FORM_ID=

NEXT_PUBLIC_SKIP_BUILD_DOCS=
NEXT_PUBLIC_SKIP_BUILD_HELPS=

# Docs
DOCS_DIR_V2=../payload/docs
DOCS_DIR_V3=../payload/docs
NEXT_PUBLIC_ENABLE_BETA_DOCS=
NEXT_PUBLIC_ENABLE_LEGACY_DOCS=
COMMIT_DOCS_API_URL=
COMMIT_DOCS_API_KEY=

# Deploy Hook URL for triggering a redeploy on Vercel
VERCEL_REDEPLOY_URL=

# RECAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PRIVATE_RECAPTCHA_SECRET_KEY=
